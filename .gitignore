# Downloaded 3D assets (large, re-downloadable via src/download_assets.py)
assets/models/plants/

# Blender temp/backup files
*.blend1
*.blend2

# Large binary outputs (generated, not source)
out/
F__home_*.blend

# Large video renders (keep local, too big for GitHub)
renders/*.mp4
renders/*.mpg

# Large presentation base64 files (regenerable from images)
presentation/b64/

# Archive binaries (keep on disk, not in git)
archive/**/*.glb
archive/**/*.obj
archive/**/*.blend

# Patent PDFs (generated, contain inventor info, don't commit)
patent/*.pdf

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
